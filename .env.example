APP_NAME="GTE-Abruzzo"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Rome
APP_URL=http://localhost
APP_PORT=80

APP_LOCALE=it
APP_FALLBACK_LOCALE=it
APP_FAKER_LOCALE=it_IT

APP_MAINTENANCE_DRIVER=file

APP_VERSION=dev
APP_VERSION_LABEL=dev
APP_VERSION_TYPE=dev

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ─────────────────────────────────────────────────────────────────
# Local dev uses SQLite. Docker prod uses MariaDB (see docker-compose.yml).
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=db
# DB_PORT=3306
# DB_DATABASE=gte_abruzzo
# DB_USERNAME=gte
# DB_PASSWORD=secret
# DB_ROOT_PASSWORD=secret
# DB_EXTERNAL_PORT=3306

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_EXTERNAL_PORT=6379

# ── Mail / PEC ────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@provincia.pescara.it"
MAIL_FROM_NAME="${APP_NAME}"

# ── SPID / CIE ───────────────────────────────────────────────────────────────
# Socialite SPID provider — configure after environment onboarding
SPID_SP_ENTITY_ID=
SPID_SP_ACS_URL=
SPID_SP_SLO_URL=
SPID_SP_PRIVATE_KEY=
SPID_SP_CERTIFICATE=
SPID_ATTRIBUTE_CONSUMING_SERVICE_INDEX=1
SPID_TEST=true

# ── Browsershot / Headless Chrome ─────────────────────────────────────────────
# Path to Chromium inside the Docker app container (set automatically in Dockerfile)
CHROMIUM_PATH=/usr/bin/chromium
# Optional: remote Chrome via browserless (alternative to local Chromium)
# BROWSERSHOT_URL=http://chrome:3000

# ── PagoPA ───────────────────────────────────────────────────────────────────
PAGOPA_BASE_URL=
PAGOPA_STATION_ID=
PAGOPA_BROKER_CODE=
PAGOPA_CHANNEL_CODE=
PAGOPA_PSP_CODE=
PAGOPA_PASSWORD=

# ── OSRM ─────────────────────────────────────────────────────────────────────
OSRM_BASE_URL=http://osrm:5000
OSRM_EXTERNAL_PORT=5000

# ── AINOP / PDND ─────────────────────────────────────────────────────────────
PDND_BASE_URL=
PDND_CLIENT_ID=
PDND_CLIENT_KEY_ID=
PDND_PRIVATE_KEY=

VITE_APP_NAME="${APP_NAME}"
