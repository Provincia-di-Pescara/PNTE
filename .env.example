# ── Framework ─────────────────────────────────────────────────────────────────
# APP_KEY: generate once with `php artisan key:generate --show` and set here.
# APP_ENV: use "production" in Portainer; "local" activates debug toolbar / Vite HMR.
# Image tag to deploy from GHCR (set by Portainer or CI). Examples: latest, v0.2.0, dev.
APP_VERSION=latest
APP_KEY=
APP_ENV=local
APP_URL=http://localhost
APP_TIMEZONE=Europe/Rome
# Port exposed to the reverse proxy (Nginx Proxy Manager / Traefik).
# Only this port exits the internal Docker network.
APP_PORT=80

# ── Database (PostgreSQL 16 + PostGIS 3.4) ───────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=pnte
DB_USERNAME=pnte
DB_PASSWORD=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Docker Compose profiles ───────────────────────────────────────────────────
# "routing" attiva osrm-init (download + preprocessing Italia ~30 min al primo
# avvio, idempotente) e il container osrm-routed.
# Impostare in Portainer → stack → environment variables; lasciare vuoto in CI.
COMPOSE_PROFILES=routing

# ── GIS Routing ───────────────────────────────────────────────────────────────
# Internal Docker network address of the OSRM container.
OSRM_BASE_URL=http://osrm:5000
# Geofabrik region path used by osrm-init for download and preprocessing.
# Format: <continent>/<country>[/<region>] — matches the Geofabrik URL structure.
# Italy sub-regions: centro | nord-est | nord-ovest | sud | isole
# Abruzzo is in "sud" 
OSRM_REGION=europe/italy/sud
# Thread count for osrm-init preprocessing (extract, partition, customize).
# Lower = less RAM; sud needs ~8-12 GB RAM at 2 threads.
# Raise on Portainer hosts with more RAM to speed up preprocessing.
OSRM_THREADS=2

# ── PDF / Headless Chrome ─────────────────────────────────────────────────────
# Chromium path is pre-set in the Docker image; change only when using a remote
# browserless instance instead of the bundled Chromium.
CHROMIUM_PATH=/usr/bin/chromium

# ── SPID / CIE — OIDC proxy (external, e.g. IAM Proxy Italia) ────────────────
# Point OIDC_URL at the issuer root of whichever proxy is deployed externally.
# OIDC_CLIENT_ID and OIDC_CLIENT_SECRET must be registered on the proxy side.
# Leave blank to disable SPID/CIE login (the button will be hidden).
OIDC_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Optional overrides when the proxy uses non-standard endpoint paths:
OIDC_AUTHORIZATION_ENDPOINT=
OIDC_TOKEN_ENDPOINT=
OIDC_USERINFO_ENDPOINT=
